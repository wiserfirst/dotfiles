#!/bin/bash
# herdr-sessionizer — create-or-focus a herdr workspace for a project directory.
#
# Usage:
#   herdr-sessionizer            interactive fzf picker (run inside a terminal)
#   herdr-sessionizer <query>    non-interactive: best fuzzy match wins
#
# Workspaces are matched by label (= repo directory basename).

export PATH="/opt/homebrew/bin:$HOME/.fzf/bin:$PATH"

# Repo roots — add more directories here as needed.
ROOTS=("$HOME/workspace" "$HOME/opensource")

candidates() {
  for root in "${ROOTS[@]}"; do
    [ -d "$root" ] || continue
    find "$root" -mindepth 1 -maxdepth 1 -type d -not -name ".*"
  done
}

query="${1:-}"
if [ -n "$query" ]; then
  dir=$(candidates | fzf --filter "$query" | head -1)
else
  dir=$(candidates | fzf --prompt="project> ")
fi

if [ -z "$dir" ]; then
  echo "no match"
  exit 1
fi

label=$(basename "$dir")

ws_id=$(herdr workspace list |
  jq -r --arg l "$label" '.result.workspaces[] | select(.label == $l) | .workspace_id' |
  head -1)

if [ -z "$ws_id" ]; then
  ws_id=$(herdr workspace create --cwd "$dir" --label "$label" |
    jq -r '.result.workspace.workspace_id')
fi

if [ -z "$ws_id" ]; then
  echo "failed to create workspace for $label"
  exit 1
fi

herdr workspace focus "$ws_id" > /dev/null
echo "→ $label"
